{
  "openapi": "3.0.3",
  "info": {
    "title": "Paiement Service API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:8093",
      "description": "Backend service"
    }
  ],
  "paths": {
    "/api/dossiers/{inscriptionId}/versements/distribuer": {
      "post": {
        "tags": [
          "dossier-paiement-controller"
        ],
        "operationId": "distribuerVersement",
        "parameters": [
          {
            "name": "inscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DistribuerVersementRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DossierPaiementResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/dossiers/{inscriptionId}": {
      "get": {
        "tags": [
          "dossier-paiement-controller"
        ],
        "operationId": "consulter",
        "parameters": [
          {
            "name": "inscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DossierPaiementResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/dossiers/{inscriptionId}/prochaine-ligne": {
      "get": {
        "tags": [
          "dossier-paiement-controller"
        ],
        "operationId": "prochaineLigne",
        "parameters": [
          {
            "name": "inscriptionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LignePaiementResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Banque": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MoyenPaiementRequest"
          },
          {
            "type": "object",
            "properties": {
              "nomBanque": {
                "type": "string"
              },
              "numeroTransaction": {
                "type": "string"
              }
            }
          }
        ]
      },
      "Comptant": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MoyenPaiementRequest"
          }
        ]
      },
      "DistribuerVersementRequest": {
        "type": "object",
        "properties": {
          "montant": {
            "type": "number"
          },
          "datePaiement": {
            "type": "string",
            "format": "date"
          },
          "moyen": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Banque"
              },
              {
                "$ref": "#/components/schemas/Comptant"
              },
              {
                "$ref": "#/components/schemas/MobileMoney"
              }
            ]
          }
        },
        "required": [
          "datePaiement",
          "montant",
          "moyen"
        ]
      },
      "MobileMoney": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MoyenPaiementRequest"
          },
          {
            "type": "object",
            "properties": {
              "operateur": {
                "type": "string"
              },
              "referencePaiement": {
                "type": "string"
              }
            }
          }
        ]
      },
      "MoyenPaiementRequest": {
        "discriminator": {
          "propertyName": "type"
        },
        "properties": {
          "type": {
            "type": "string"
          }
        },
        "required": [
          "type"
        ]
      },
      "DossierPaiementResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "inscriptionId": {
            "type": "string",
            "format": "uuid"
          },
          "etudiantId": {
            "type": "string",
            "format": "uuid"
          },
          "classeId": {
            "type": "string",
            "format": "uuid"
          },
          "codeAnnee": {
            "type": "string"
          },
          "fraisInscription": {
            "type": "number"
          },
          "mensualite": {
            "type": "number"
          },
          "autresFrais": {
            "type": "number"
          },
          "statut": {
            "type": "string",
            "enum": [
              "INITIALISE",
              "ACTIF",
              "CLOTURE"
            ]
          },
          "lignes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LignePaiementResponse"
            }
          }
        }
      },
      "LignePaiementResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string",
            "enum": [
              "FRAIS_INSCRIPTION",
              "AUTRES_FRAIS",
              "MENSUALITE"
            ]
          },
          "moisAcademique": {
            "$ref": "#/components/schemas/MoisAcademique"
          },
          "ordreReglement": {
            "type": "integer",
            "format": "int32"
          },
          "montantDu": {
            "type": "number"
          },
          "montantPaye": {
            "type": "number"
          },
          "montantRestant": {
            "type": "number"
          },
          "commentaire": {
            "type": "string"
          },
          "statut": {
            "type": "string",
            "enum": [
              "APAYER",
              "AVANCE",
              "PAYE"
            ]
          }
        }
      },
      "MoisAcademique": {
        "type": "object",
        "properties": {
          "mois": {
            "type": "integer",
            "format": "int32"
          },
          "annee": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
  }
}