{
  "openapi": "3.0.3",
  "info": {
    "title": "Etudiant Service API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:8092",
      "description": "Backend service"
    }
  ],
  "paths": {
    "/api/etudiants/{matricule}": {
      "get": {
        "tags": [
          "etudiant-controller"
        ],
        "operationId": "rechercherParMatricule",
        "parameters": [
          {
            "name": "matricule",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/EtudiantResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "etudiant-controller"
        ],
        "operationId": "modifier",
        "parameters": [
          {
            "name": "matricule",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModifierEtudiantRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/etudiants": {
      "post": {
        "tags": [
          "etudiant-controller"
        ],
        "operationId": "creer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreerEtudiantRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/EtudiantResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/etudiants/id/{id}": {
      "get": {
        "tags": [
          "etudiant-controller"
        ],
        "operationId": "rechercherParId",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/EtudiantResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "etudiant-controller"
        ],
        "operationId": "supprimer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ModifierEtudiantRequest": {
        "type": "object",
        "properties": {
          "nom": {
            "type": "string",
            "minLength": 1
          },
          "prenom": {
            "type": "string",
            "minLength": 1
          },
          "dateNaissance": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "dateNaissance",
          "nom",
          "prenom"
        ]
      },
      "CreerEtudiantRequest": {
        "type": "object",
        "properties": {
          "nom": {
            "type": "string",
            "minLength": 1
          },
          "prenom": {
            "type": "string",
            "minLength": 1
          },
          "dateNaissance": {
            "type": "string",
            "format": "date"
          },
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 1
          },
          "codeAnnee": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "codeAnnee",
          "dateNaissance",
          "email",
          "nom",
          "prenom"
        ]
      },
      "EtudiantResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "matricule": {
            "type": "string"
          },
          "nom": {
            "type": "string"
          },
          "prenom": {
            "type": "string"
          },
          "dateNaissance": {
            "type": "string",
            "format": "date"
          },
          "email": {
            "type": "string"
          }
        }
      }
    }
  }
}