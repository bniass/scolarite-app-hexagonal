{
  "openapi": "3.0.3",
  "info": {
    "title": "Annee Academique Service API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:8080",
      "description": "Backend service"
    }
  ],
  "tags": [
    {
      "name": "AnneeAcademique",
      "description": "Gestion de l'année académique"
    }
  ],
  "paths": {
    "/api/academic-years": {
      "post": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "creer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreerAnneeAcademiqueRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/academic-years/{code}/update": {
      "post": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "modifier",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModifierAnneeAcademiqueCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/academic-years/{code}/publish": {
      "get": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "publier",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/academic-years/{code}/open-enrollments": {
      "get": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "ouvrirInscriptions",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/academic-years/{code}/close": {
      "get": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "cloturer",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/academic-years/{code}/close-enrollments": {
      "get": {
        "tags": [
          "AnneeAcademique"
        ],
        "operationId": "fermerInscriptions",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "CreerAnneeAcademiqueRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[0-9]{4}$"
          },
          "dateDebut": {
            "type": "string",
            "format": "date"
          },
          "dateFin": {
            "type": "string",
            "format": "date"
          },
          "dateDebutInscriptions": {
            "type": "string",
            "format": "date"
          },
          "dateFinInscriptions": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "code"
        ]
      },
      "ModifierAnneeAcademiqueCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "dateDebut": {
            "type": "string",
            "format": "date"
          },
          "dateFin": {
            "type": "string",
            "format": "date"
          },
          "dateDebutInscriptions": {
            "type": "string",
            "format": "date"
          },
          "dateFinInscriptions": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}